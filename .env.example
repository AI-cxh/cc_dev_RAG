# OpenAI compatible API
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# VLLM (local)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=vllm-model-name

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# =====================================================
# Embedding Configuration
# =====================================================
EMBEDDING_MODEL_VENDOR=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# BGE-M3 (local)
# EMBEDDING_MODEL_VENDOR=local
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_DIMENSION=1024

# =====================================================
# Reranker Configuration
# =====================================================
RERANKER_ENABLED=true
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_TOP_K=10

# =====================================================
# Milvus Configuration
# =====================================================
MILVUS_HOST=localhost
MILVUS_PORT=19532
MILVUS_TOKEN=root:Milvus

# =====================================================
# Database Configuration
# =====================================================
DATABASE_URL=sqlite:///./data/dialogues.db

# =====================================================
# Application Configuration
# =====================================================
APP_NAME=RAG Agent Assistant
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# =====================================================
# RAG Configuration
# =====================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=0.1
MAX_RETRIEVAL_RESULTS=20
TOP_K_RESULTS=5

# Query Routing
WEB_SEARCH_KEYWORDS=搜索,最新,实时,今天,本周,本月,新闻
REWRITE_THRESHOLD=0.6
MAX_REWRITE_ATTEMPTS=2

# =====================================================
# Frontend Configuration
# =====================================================
FRONTEND_URL=http://localhost:5173
